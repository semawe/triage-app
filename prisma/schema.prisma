generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth required models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  orgMemberships   OrganisationMember[]
  spaceMemberships SpaceMember[]
  roleAssignments  RoleAssignment[]
  agendaItems      AgendaItem[]
  outputs          Output[]
  assignedOutputs  Output[]             @relation("OutputAssignee")
  superAdmin       SuperAdmin?
  joinRequests     JoinRequest[]
  hostedMeetings   Meeting[]            @relation("MeetingHost")
  scribedMeetings  Meeting[]            @relation("MeetingScribe")
  meetingGuests    MeetingGuest[]
  indicatorValues  IndicatorValue[]
  checklistChecks  ChecklistCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  trial
  active
  past_due
  canceled
}

model Organisation {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  logoUrl      String?
  primaryColor String? // hex ex: "#6366f1"
  features     Json    @default("{}")

  // Domain auto-join
  allowedEmailDomain String? // ex: "semawe.fr" — members with matching domain can request to join

  // Billing
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(trial)
  stripeSubId        String?            @unique
  seatCount          Int                @default(3)
  trialEndsAt        DateTime?

  // Coordonnées de facturation (données légales/fiscales du client, portées sur la facture)
  billingName         String? // raison sociale facturée (peut différer du nom d'affichage)
  billingContactName  String? // nom et prénom du contact facturation (« à l'attention de »)
  billingEmail        String? // contact de facturation (destinataire des factures)
  billingAddressLine1 String?
  billingAddressLine2 String?
  billingPostalCode   String?
  billingCity         String?
  billingCountry      String? @default("FR")
  siret               String? // SIRET (établissement français)
  vatNumber           String? // n° TVA intracommunautaire

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganisationMember[]
  spaces         Space[]
  pendingInvites PendingInvite[]
  joinRequests   JoinRequest[]
}

enum OrgRole {
  admin
  member
}

model OrganisationMember {
  id             String   @id @default(cuid())
  organisationId String
  userId         String
  role           OrgRole  @default(member)
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
  @@index([userId]) // requireOrg() filtre par userId à chaque page authentifiée
}

enum SpaceType {
  circle
  project
  instance // codir, board, comité, etc.
}

model Space {
  id               String    @id @default(cuid())
  organisationId   String
  parentId         String?
  name             String
  type             SpaceType
  purpose          String?   @db.Text
  strategy         String?   @db.Text // heuristiques de priorisation du cercle ("stratégie de cercle" Holacracy)
  domains          String[]
  accountabilities String[]
  isPrivate        Boolean   @default(false)
  features         Json? // override par-espace des modules (clé absente ou null = hérite de l'org)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  parent         Space?          @relation("SpaceChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Space[]         @relation("SpaceChildren")
  members        SpaceMember[]
  meetings       Meeting[]
  roles          Role[]
  policies       Policy[]
  indicators     Indicator[]
  checklistItems ChecklistItem[]
  projects       Project[]

  @@index([organisationId])
}

model Policy {
  id        String   @id @default(cuid())
  spaceId   String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

enum SpaceRole {
  lead
  member
}

model SpaceMember {
  id        String    @id @default(cuid())
  spaceId   String
  userId    String
  role      SpaceRole @default(member)
  createdAt DateTime  @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
}

enum MeetingStatus {
  draft
  open
  closed
}

model Meeting {
  id              String        @id @default(cuid())
  spaceId         String
  title           String?       // optionnel — sinon on affiche la date
  link            String?       // lien visio, Fireflies, etc.
  date            DateTime
  durationMinutes Int?
  status          MeetingStatus @default(draft)
  isPrivate       Boolean?      // null = hérite de l'espace, true/false = override
  openedAt        DateTime?
  syncCompletedAt DateTime?     // phase de synchro terminée (null + module actif = triage pas encore démarré)
  createdById     String?       // hôte de la réunion (créateur) — peut inviter des invités ponctuels
  scribeId        String?       // scribe : seul autorisé à saisir/éditer les outputs (retour #32). Défini à l'ouverture (l'ouvreur par défaut), transmissible.
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  space           Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  host            User?            @relation("MeetingHost", fields: [createdById], references: [id], onDelete: SetNull)
  scribe          User?            @relation("MeetingScribe", fields: [scribeId], references: [id], onDelete: SetNull)
  agendaItems     AgendaItem[]
  guests          MeetingGuest[]
  indicatorValues IndicatorValue[]
  checklistChecks ChecklistCheck[]

  @@index([spaceId])
}

// Invité ponctuel à une réunion : accès par lien/jeton, sans compte ni
// appartenance à l'organisation (retour de test #31). Ne consomme pas de siège.
model MeetingGuest {
  id        String    @id @default(cuid())
  meetingId String
  email     String
  name      String?
  token     String    @unique @default(cuid())
  userId    String?   // User léger créé à la première entrée (pour l'authorship des points)
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([meetingId, email])
  @@index([meetingId])
}

enum ItemStatus {
  pending
  active
  done
}

model AgendaItem {
  id        String     @id @default(cuid())
  meetingId String
  authorId  String
  title     String
  order     Int
  status    ItemStatus @default(pending)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  meeting Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id])
  outputs Output[]

  @@index([meetingId])
}

model Role {
  id               String   @id @default(cuid())
  spaceId          String
  name             String
  purpose          String?  @db.Text
  domains          String[]
  accountabilities String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  space       Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  assignments RoleAssignment[]
}

model RoleAssignment {
  id        String    @id @default(cuid())
  roleId    String
  userId    String
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roleId, userId])
}

model PendingInvite {
  id        String   @id @default(cuid())
  orgId     String
  role      OrgRole  @default(member)
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

enum JoinRequestStatus {
  pending
  approved
  rejected
}

model JoinRequest {
  id             String            @id @default(cuid())
  userId         String
  organisationId String
  status         JoinRequestStatus @default(pending)
  createdAt      DateTime          @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
}

model SuperAdmin {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum OutputType {
  note
  action
  decision
  project
  governance
}

model Output {
  id         String     @id @default(cuid())
  itemId     String
  authorId   String
  type       OutputType
  content    String     @db.Text
  assigneeId String?
  dueDate    DateTime?
  isDone     Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  item     AgendaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author   User       @relation(fields: [authorId], references: [id])
  assignee User?      @relation("OutputAssignee", fields: [assigneeId], references: [id])

  @@index([itemId])
}

// ── Phase de synchro (réunion tactique) ──────────────────────────────────────
// Indicateurs, checklists et projets d'un espace, passés en revue avant le
// triage quand le module sync_phase est actif (org ou override par espace).

model Indicator {
  id        String   @id @default(cuid())
  spaceId   String
  name      String
  unit      String? // ex: "€", "%", "clients"
  frequency String? // libre : "hebdo", "mensuel"…
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space  Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  values IndicatorValue[]

  @@index([spaceId])
}

model IndicatorValue {
  id          String   @id @default(cuid())
  indicatorId String
  meetingId   String
  authorId    String
  value       Float
  note        String?  @db.Text
  recordedAt  DateTime @default(now())

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  @@unique([indicatorId, meetingId]) // un seul relevé par indicateur et par réunion (upsert)
  @@index([indicatorId])
  @@index([meetingId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  spaceId   String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space  Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  checks ChecklistCheck[]

  @@index([spaceId])
}

// Coche d'un item de checklist pour une réunion donnée. Pas de ligne = non
// coché : la checklist repart vierge à chaque réunion, sans job de reset.
model ChecklistCheck {
  id        String    @id @default(cuid())
  itemId    String
  meetingId String
  isDone    Boolean   @default(false)
  checkedBy String?
  checkedAt DateTime?

  item    ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  meeting Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  checker User?         @relation(fields: [checkedBy], references: [id], onDelete: SetNull)

  @@unique([itemId, meetingId])
  @@index([meetingId])
}

enum ProjectStatus {
  active
  on_hold
  done
}

model Project {
  id          String        @id @default(cuid())
  spaceId     String
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}
