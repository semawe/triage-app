# Copier vers /home/debian/triage-app/.env.local sur le VPS
# Ne jamais committer ce fichier avec de vraies valeurs

DATABASE_URL="postgresql://<user>@localhost:5432/triageapp_prod"

# NextAuth v5
AUTH_SECRET="<générer : openssl rand -base64 32>"
AUTH_URL="https://triapp.fr"
AUTH_TRUST_HOST=true

# Google OAuth — créer des credentials prod sur console.cloud.google.com
# URI de redirection autorisé : https://triapp.fr/api/auth/callback/google
GOOGLE_CLIENT_ID="<id-prod>"
GOOGLE_CLIENT_SECRET="<secret-prod>"

# Stripe prod (dashboard.stripe.com → switcher Live mode)
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

NEXT_PUBLIC_APP_URL="https://triapp.fr"

# Brevo SMTP relay (smtp-relay.brevo.com:587)
BREVO_SMTP_USER="<username@smtp-brevo.com>"
BREVO_SMTP_PASSWORD="<clé-smtp-brevo>"
EMAIL_FROM="noreply@triapp.fr"
